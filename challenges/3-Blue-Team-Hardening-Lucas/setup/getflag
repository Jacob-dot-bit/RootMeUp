#!/bin/bash
# =============================================================================
#  getflag  -  Client joueur (dans le conteneur). NE CONTIENT AUCUN FLAG.
#  Demande au serveur de validation le flag d'une tâche ; le serveur re-vérifie
#  lui-même l'état de l'instance et ne renvoie le flag que si c'est durci.
#  Usage : getflag <numero_de_1_a_10>
# =============================================================================
N="$1"
: "${GRADER_URL:=http://host.docker.internal:9000}"

case "$N" in
  ''|*[!0-9]*) echo "Usage : getflag <numero de 1 a 10>"; exit 1 ;;
esac

resp="$(curl -s -m 10 "$GRADER_URL/flag" --data "task=$N" --data "cid=$(hostname)" 2>/dev/null)"
if [ -z "$resp" ]; then
  echo "Serveur de validation injoignable ($GRADER_URL)."
  echo "Verifie avec l'admin que le service grader tourne."
  exit 1
fi

flag="$(printf '%s' "$resp" | grep -o '"flag"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:[[:space:]]*"//;s/"$//')"
if [ -n "$flag" ]; then
  echo "[OK] Tache $N validee !"
  echo "     Flag : $flag"
  echo "     -> a soumettre dans CTFd"
else
  msg="$(printf '%s' "$resp" | grep -o '"msg"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*:[[:space:]]*"//;s/"$//')"
  echo "[KO] Tache $N : ${msg:-pas encore validee}"
fi
