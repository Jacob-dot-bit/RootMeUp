# =====================================================================
#  Modele de configuration du flag — challenge Memory Forensics.
#
#  1. Copiez :   cp challenge.env.example challenge.env
#  2. Mettez le VRAI flag (roté) dans challenge.env
#  3. challenge.env est gitignore : il ne sera jamais committe.
#
#  Le flag est ensuite cuit dans le dump/PCAP au build, et son hash
#  SHA256 est genere pour le validateur. Alternative : passer FLAG en
#  variable d'environnement / --build-arg (priorite sur ce fichier).
# =====================================================================

FLAG=blue{exemple_a_changer}
