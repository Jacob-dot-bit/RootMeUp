# =====================================================================
#  Modele de configuration des secrets du challenge VAULT-9.
#
#  1. Copiez ce fichier :   cp challenge.env.example challenge.env
#  2. Renseignez les VRAIES valeurs dans challenge.env
#  3. challenge.env est gitignore : il ne sera jamais committe.
#
#  Alternative : passer ces valeurs en --build-arg au docker build
#  (les variables d'environnement ont priorite sur ce fichier).
# =====================================================================

# Licence attendue par l'etape reverse (etape 1)
LICENSE=exemple_a_changer

# Flag de l'etape reverse (etape 1)
FLAG1=RM{exemple_flag_reverse_a_changer}

# Flag de l'etape exploitation ret2win (etape 2)
FLAG2=RM{exemple_flag_pwn_a_changer}

# Cle de XOR mono-octet (0x.. ou decimal). Non sensible, defaut 0x5c.
XOR_KEY=0x5c
